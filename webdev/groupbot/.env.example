# Group bot — internal team bot for /excel and /pdf inside the sales group.
# These values come from the single root webdev/.env (docker-compose passes them in).
SALES_BOT_TOKEN=YOUR_GROUP_BOT_TOKEN_FROM_BOTFATHER
SALES_CHAT_ID=-1001234567890
BACKEND_URL=http://backend:4001
# Must match BOT_SHARED_SECRET on the backend. REQUIRED — exports are disabled without it.
BOT_SHARED_SECRET=
