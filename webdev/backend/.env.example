PORT=4001
NODE_ENV=development

# --- JWT (rotate for production) ---
# Generate with: openssl rand -hex 32
JWT_SECRET=your_jwt_secret_here
JWT_REFRESH_SECRET=your_refresh_secret_here

# --- Admin credentials ---
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_this_password

# --- PII encryption (Fernet) — REQUIRED in production ---
# Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
PII_ENCRYPTION_KEY=change_this_fernet_key

# --- CORS ---
CORS_ORIGIN=http://localhost:5173

# --- PostgreSQL ---
DATABASE_URL=postgresql://user:password@localhost:5432/bizzcheck
DB_HOST=localhost
DB_PORT=5432
DB_NAME=bizzcheck
DB_USER=postgres
DB_PASSWORD=postgres

# --- Telegram bot bridge (used by the frontend to build deep-link URLs) ---
TELEGRAM_BOT_USERNAME=YOUR_BOT_USERNAME
