# ─── BizCheck — Single Environment File ─────────────────────
# Copy this to .env and fill in your values before running docker compose up.
# All services (db, backend, frontend, tgbot) read from this single file.

# ── Database ──
DB_NAME=bizzcheck
DB_USER=postgres
DB_PASSWORD=CHANGE_THIS_STRONG_DB_PASSWORD

# ── Backend ──
JWT_SECRET=CHANGE_THIS_STRONG_JWT_SECRET
JWT_REFRESH_SECRET=CHANGE_THIS_STRONG_REFRESH_SECRET
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGE_THIS_STRONG_ADMIN_PASSWORD
# Fernet key for PII encryption at rest. REQUIRED in production.
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
PII_ENCRYPTION_KEY=CHANGE_THIS_FERNET_KEY
# Local: http://localhost:5173  |  Production: https://bizcheck.ua.com
CORS_ORIGIN=https://bizcheck.ua.com
NODE_ENV=production

# ── Frontend ──
FRONTEND_PORT=5173

# ── Telegram Bot (client-facing report bot) ──
TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN_FROM_BOTFATHER
TELEGRAM_BOT_USERNAME=YOUR_BOT_USERNAME

# ── Team group bot (notifications + /excel + /pdf) ──
# A SECOND bot from BotFather, added as admin (with "Manage Topics") to your team
# group. The backend posts test-completed notifications into a per-test topic and
# the groupbot service serves /excel and /pdf. Leave SALES_BOT_TOKEN empty to disable.
SALES_BOT_TOKEN=YOUR_GROUP_BOT_TOKEN_FROM_BOTFATHER
# OPTIONAL group id (negative, e.g. -1001234567890). Normally you leave this EMPTY
# and run /register in the group instead — the owner-only command binds the group at
# runtime (stored in site_settings.sales_chat_id).
# When set, this WINS over whatever /register bound: it is the operator kill-switch
# that pins leads to a known-good group and cannot be overridden from Telegram. Use
# it to recover from a bad or hostile /register — then clear it to hand control back.
SALES_CHAT_ID=
# Topic (message_thread_id) to which ALL lead notifications are pinned.
# LEAVE EMPTY for the normal setup: an own topic is then created automatically for
# each test (cached in tests.tg_topic_id). Setting this takes priority and collapses
# every test into this single topic — only do that if you really want one topic.
# (If the group is not a forum, or the bot lacks "Manage Topics", it falls back to General.)
SALES_TOPIC_ID=
# Shared secret between the backend and BOTH bot services (tgbot + groupbot).
# REQUIRED for /excel and /client to work (export endpoints are disabled without it).
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
BOT_SHARED_SECRET=
# Admin panel URL shown by /pdf (bulk PDFs are downloaded from the panel, not Telegram).
ADMIN_PANEL_URL=https://bizcheck.ua.com/admin_bizcheck_md_crowe/
# Background scheduler that sends due feedback questions (services/feedback.py).
# Defaults to "1" (on) when unset. Set to "0" to disable the loop entirely.
FEEDBACK_SCHEDULER=1

# ── Email delivery (Office 365 SMTP) ──
# 1. Go to https://mysignins.microsoft.com/security-info for office@bizcheck.md
# 2. Add sign-in method → "App password" → name it "bizcheck-smtp"
# 3. Copy the 16-char generated password here.
# If these are empty, the email feature is silently disabled (no crash).
# IMPORTANT: SMTP_USER is the From address — keep it on the bizcheck.md domain
# so SPF/DKIM/DMARC and the Message-ID/link domain all align (anti-spam).
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=office@bizcheck.md
SMTP_PASSWORD=
SMTP_FROM_NAME=Crowe Turcan Mikhailenko
SMTP_REPLY_TO=office@bizcheck.md
# Publicly reachable logo URL used inside the HTML email template.
EMAIL_LOGO_URL=https://bizcheck.ua.com/logo_email.png
