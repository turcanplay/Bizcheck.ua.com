# ─── BizCheck — Single Environment File ─────────────────────
# Copy this to .env and fill in your values before running docker compose up.
# All services (db, backend, frontend, tgbot) read from this single file.

# ── Database ──
DB_NAME=bizzcheck
DB_USER=postgres
DB_PASSWORD=CHANGE_THIS_STRONG_DB_PASSWORD

# ── Backend ──
JWT_SECRET=CHANGE_THIS_STRONG_JWT_SECRET
JWT_REFRESH_SECRET=CHANGE_THIS_STRONG_REFRESH_SECRET
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGE_THIS_STRONG_ADMIN_PASSWORD
# Fernet key for PII encryption at rest. REQUIRED in production.
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
PII_ENCRYPTION_KEY=CHANGE_THIS_FERNET_KEY
# Local: http://localhost:5173  |  Production: https://bizcheck.md
CORS_ORIGIN=https://bizcheck.md
NODE_ENV=production

# ── Frontend ──
FRONTEND_PORT=5173

# ── Telegram Bot ──
TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN_FROM_BOTFATHER
TELEGRAM_BOT_USERNAME=YOUR_BOT_USERNAME

# ── Email delivery (Office 365 SMTP) ──
# 1. Go to https://mysignins.microsoft.com/security-info for office@bizcheck.md
# 2. Add sign-in method → "App password" → name it "bizcheck-smtp"
# 3. Copy the 16-char generated password here.
# If these are empty, the email feature is silently disabled (no crash).
# IMPORTANT: SMTP_USER is the From address — keep it on the bizcheck.md domain
# so SPF/DKIM/DMARC and the Message-ID/link domain all align (anti-spam).
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=office@bizcheck.md
SMTP_PASSWORD=
SMTP_FROM_NAME=Crowe Turcan Mikhailenko
SMTP_REPLY_TO=office@bizcheck.md
# Publicly reachable logo URL used inside the HTML email template.
EMAIL_LOGO_URL=https://bizcheck.md/logo_email.png
