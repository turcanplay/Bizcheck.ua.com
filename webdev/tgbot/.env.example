# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN_FROM_BOTFATHER

# Username of the bot (without @), used to build deep links
TELEGRAM_BOT_USERNAME=CROWE_BIZCHECK_bot

# Internal URL of the backend service (inside Docker network)
BACKEND_URL=http://backend:4001

# Shared secret for the bot-only feedback endpoints (/tg/feedback/*).
# Must match BOT_SHARED_SECRET on the backend. Leave empty to run ungated (dev).
BOT_SHARED_SECRET=
